{
    "_comment": "Documents the pipeline config stored at config/config.json in the district data bucket",
    "_instructions": [
        "To get the school values (id, classification, email), inspect network calls in AISR:",
        "1. Log into AISR website and navigate to a school",
        "2. Open browser developer tools -> Network tab and filter by 'Fetch/XHR'",
        "3. Click 'Bulk Query' for the school you want to configure",
        "4. Look for a GET request to 'https://aisr-api.web.health.state.mn.us/school/<school_id>'",
        "5. This request response contains the id, classification, and email values needed",
        "6. The 'name' field can be any descriptive name, but id, classification, and email must match AISR exactly",
        "7. bulk_query_file is the GCS blob path (within the data bucket) of the school's roster CSV"
    ],
    "_mock_server": [
        "For end-to-end testing, a mock server is available:",
        "Local development: auth_base_url: http://localhost:8080/mock-auth-server, aisr_api_base_url: http://localhost:8080",
        "Mock server has hardcoded school IDs: 2542 (Friendly Hills Mid), 2543 (Garlough Elementary)"
    ],
    "api": {
        "auth_base_url": "https://authenticator4.web.health.state.mn.us",
        "aisr_api_base_url": "https://aisr-api.web.health.state.mn.us"
    },
    "schools": [
        {
            "name": "Friendly Hills Mid (Mock Server)",
            "id": "2542",
            "classification": "N",
            "email": "nurse@friendlyhills.example.org",
            "bulk_query_file": "data/queries/friendly_hills_students.csv"
        },
        {
            "name": "Garlough Elementary (Mock Server)",
            "id": "2543",
            "classification": "N",
            "email": "health@garlough.example.org",
            "bulk_query_file": "data/queries/garlough_students.csv"
        }
    ]
}
